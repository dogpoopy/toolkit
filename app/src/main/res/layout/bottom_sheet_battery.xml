<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="32dp">
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_sheet_handle" />
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingBottom="12dp"
        android:text="@string/battery_stats_title"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="?android:attr/textColorPrimary" />
    <ProgressBar
        android:id="@+id/progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_margin="32dp"
        android:indeterminateTint="@color/samsung_blue"
        android:visibility="visible" />
    <LinearLayout
        android:id="@+id/layoutContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginVertical="16dp">
            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/progressHealth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="0"
                app:indicatorSize="120dp"
                app:trackThickness="10dp"
                app:trackColor="@color/divider"
                app:indicatorColor="@color/samsung_blue" />
            <LinearLayout
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/tvHealthPct"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="?android:attr/textColorPrimary" />
                <TextView
                    android:id="@+id/tvHealthLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/battery_health"
                    android:textSize="11sp"
                    android:textColor="?android:attr/textColorSecondary" />
            </LinearLayout>
        </FrameLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:layout_marginHorizontal="20dp" android:layout_marginBottom="4dp"
            android:background="@color/divider" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingHorizontal="20dp"
            android:paddingVertical="9dp" android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Charge Cycles"
                android:textSize="14sp" android:textColor="?android:attr/textColorSecondary" />
            <TextView android:id="@+id/tvCycles" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="—"
                android:textSize="14sp" android:textColor="?android:attr/textColorPrimary" />
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingHorizontal="20dp"
            android:paddingVertical="9dp" android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="First Use Date"
                android:textSize="14sp" android:textColor="?android:attr/textColorSecondary" />
            <TextView android:id="@+id/tvDate" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="—"
                android:textSize="14sp" android:textColor="?android:attr/textColorPrimary" />
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingHorizontal="20dp"
            android:paddingVertical="9dp" android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Capacity"
                android:textSize="14sp" android:textColor="?android:attr/textColorSecondary" />
            <TextView android:id="@+id/tvCap" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="—"
                android:textSize="14sp" android:textColor="?android:attr/textColorPrimary" />
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:layout_marginHorizontal="20dp" android:layout_marginVertical="4dp"
            android:background="@color/divider" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingHorizontal="20dp"
            android:paddingVertical="9dp" android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Level"
                android:textSize="14sp" android:textColor="?android:attr/textColorSecondary" />
            <TextView android:id="@+id/tvLevel" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="—"
                android:textSize="14sp" android:textColor="?android:attr/textColorPrimary" />
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingHorizontal="20dp"
            android:paddingVertical="9dp" android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Voltage"
                android:textSize="14sp" android:textColor="?android:attr/textColorSecondary" />
            <TextView android:id="@+id/tvVoltage" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="—"
                android:textSize="14sp" android:textColor="?android:attr/textColorPrimary" />
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingHorizontal="20dp"
            android:paddingVertical="9dp" android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Temperature"
                android:textSize="14sp" android:textColor="?android:attr/textColorSecondary" />
            <TextView android:id="@+id/tvTemp" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="—"
                android:textSize="14sp" android:textColor="?android:attr/textColorPrimary" />
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingHorizontal="20dp"
            android:paddingVertical="9dp" android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Current Draw"
                android:textSize="14sp" android:textColor="?android:attr/textColorSecondary" />
            <TextView android:id="@+id/tvCurrent" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="—"
                android:textSize="14sp" android:textColor="?android:attr/textColorPrimary" />
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingHorizontal="20dp"
            android:paddingVertical="9dp" android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Technology"
                android:textSize="14sp" android:textColor="?android:attr/textColorSecondary" />
            <TextView android:id="@+id/tvTech" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="—"
                android:textSize="14sp" android:textColor="?android:attr/textColorPrimary" />
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingHorizontal="20dp"
            android:paddingVertical="9dp" android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Status"
                android:textSize="14sp" android:textColor="?android:attr/textColorSecondary" />
            <TextView android:id="@+id/tvStatus" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="—"
                android:textSize="14sp" android:textColor="?android:attr/textColorPrimary" />
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:id="@+id/bannerShizuku"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_banner"
        android:padding="16dp"
        android:visibility="gone">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/shizuku_banner_title"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_marginBottom="4dp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/shizuku_banner_body"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="12dp" />
        <Button
            android:id="@+id/btnUpgradeShizuku"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setup_shizuku" />
    </LinearLayout>
</LinearLayout>
